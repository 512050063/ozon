{
  "name": "ozon-crawler-backend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --ignore 'src/**/*.spec.ts' --exec ts-node --transpileOnly src/entry.ts",
    "build": "tsc",
    "test": "node ../scripts/run-script-tests.mjs",
    "test:scripts": "node ../scripts/run-script-tests.mjs",
    "audit:console": "node ../scripts/audit-console-output.mjs",
    "audit:health": "node ../scripts/audit-project-health.mjs",
    "check": "npm run build && npm run test",
    "start": "node dist/entry.js",
    "db:init": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "init:database": "ts-node src/scripts/initDatabase.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "express-fileupload": "^1.5.2",
    "express-validator": "^7.0.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "playwright": "^1.60.0",
    "prisma": "^6.19.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/express-fileupload": "^1.5.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
